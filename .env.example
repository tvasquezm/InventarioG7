# Puerto del servicio de inventario (Grupo 7) segun el estandar del curso.
# En local se usa 3006; en Render se ignora porque la plataforma inyecta su propio PORT.
PORT=3006

# Connection string de Postgres (Supabase) - Fase 3.
# Supabase -> Project Settings -> Database -> Connection string -> URI.
# Reemplaza [YOUR-PASSWORD] por la contrasena del proyecto.
# NUNCA subir el .env real con la contrasena: solo este .env.example va al repo.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Schema dedicado del servicio (database-per-service).
# En el Supabase compartido del curso, el schema de G7 es 'inventario'.
DB_SCHEMA=inventario
