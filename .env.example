# Puerto del servicio de inventario (Grupo 7) segun el estandar del curso.
# En local se usa 3006; en Render se ignora porque la plataforma inyecta su propio PORT.
PORT=3006

# Connection string de Postgres (proyecto Supabase PROPIO del Grupo 7) - Fase 3.
# Cada grupo tiene su propia base de datos: este apunta al proyecto Supabase de G7.
# USAR EL SESSION POOLER (IPv4): Supabase -> Connect -> Session pooler.
# La conexion "directa" (db.<ref>.supabase.co) es IPv6 y falla en Render (ENETUNREACH).
# Reemplaza [PROJECT-REF] y [YOUR-PASSWORD] por los de NUESTRO proyecto.
# NUNCA subir el .env real con la contrasena: solo este .env.example va al repo.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# Schema dedicado del servicio. Ahora que la BD es propia del grupo, el schema
# 'inventario' vive solo en nuestro proyecto (ya no convive con otros grupos).
DB_SCHEMA=inventario

# Catalogo de G3 (Fase 4 - integracion REST).
# Base URL publica del catalog-service; el timeout es generoso porque
# Render free duerme el servicio (cold start ~30s).
CATALOG_BASE_URL=https://catalog-api-cm1l.onrender.com/api/v1
CATALOG_TIMEOUT_MS=60000

# Identity Service de G2 (Fase 4 - proteccion de la carga de stock).
# POST /inventory/{id}/stock valida el JWT y rol admin contra GET /auth/validate.
AUTH_BASE_URL=https://auth-minimarket-cloud.onrender.com
AUTH_TIMEOUT_MS=60000

# Broker de eventos compartido del curso (Fase 4): RabbitMQ en CloudAMQP.
# Exchange topic 'payments.events' (el mismo que usan G5 y G6).
# Pedir la URL al curso; NUNCA commitear la real.
RABBITMQ_URL=amqps://usuario:password@host.rmq.cloudamqp.com/vhost
RABBITMQ_EXCHANGE=payments.events
# Frecuencia del despacho del outbox (ms).
OUTBOX_INTERVAL_MS=5000
# Cola propia de G7 en el broker (durable; acumula eventos si el servicio duerme).
RABBITMQ_QUEUE=g7-inventory-service
# Frecuencia del job batch de expiracion de reservas vencidas (ms).
EXPIRY_INTERVAL_MS=60000
