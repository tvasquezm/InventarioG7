# Puerto del servicio de inventario (Grupo 7) segun el estandar del curso.
# En local se usa 3006; en Render se ignora porque la plataforma inyecta su propio PORT.
PORT=3006

# Connection string de Postgres (proyecto Supabase PROPIO del Grupo 7) - Fase 3.
# Cada grupo tiene su propia base de datos: este apunta al proyecto Supabase de G7.
# USAR EL SESSION POOLER (IPv4): Supabase -> Connect -> Session pooler.
# La conexion "directa" (db.<ref>.supabase.co) es IPv6 y falla en Render (ENETUNREACH).
# Reemplaza [PROJECT-REF] y [YOUR-PASSWORD] por los de NUESTRO proyecto.
# NUNCA subir el .env real con la contrasena: solo este .env.example va al repo.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres

# Schema dedicado del servicio. Ahora que la BD es propia del grupo, el schema
# 'inventario' vive solo en nuestro proyecto (ya no convive con otros grupos).
DB_SCHEMA=inventario
