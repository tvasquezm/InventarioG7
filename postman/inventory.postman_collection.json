  {
   "name": "3. Obtener Stock de Producto Específico",
   "event": [
    {
     "listen": "test",
     "script": {
      "type": "text/javascript",
      "exec": [
       "pm.test('Responde 200 OK', () => pm.response.to.have.status(200));",
       "pm.test('Expone los campos de stock (incluye virtualStock)', () => {",
       "  const body = pm.response.json();",
       "  pm.expect(body).to.have.property('availableStock');",
       "  pm.expect(body).to.have.property('reservedStock');",
       "  pm.expect(body).to.have.property('totalStock');",
       "  pm.expect(body).to.have.property('virtualStock');",
       "});"
      ]
     }
    }
