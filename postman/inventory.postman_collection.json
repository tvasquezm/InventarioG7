      "key": "X-Correlation-Id",
      "value": "{{$guid}}",
      "type": "text"
     },
     {
      "key": "X-Consumer",
      "value": "postman-test-client",
      "type": "text"
     }
    ],
    "url": {
     "raw": "{{baseUrl}}/inventory?page=1&size=10",
     "host": [
      "{{baseUrl}}"
