  {
   "name": "6. Sincronizar catalogo (G3) - idempotente",
   "event": [
    {
     "listen": "test",
     "script": {
      "type": "text/javascript",
      "exec": [
       "pm.test('Sincronizacion OK (200)', () => pm.response.to.have.status(200));",
       "const body = pm.response.json();",
       "pm.test('Leyo el catalogo de G3', () => pm.expect(body.catalogProducts).to.be.above(0));",
       "pm.test('Idempotente: no duplica productos ya inventariados', () => {",
       "  pm.expect(body.created + body.alreadyTracked + body.skippedInactive).to.eql(body.catalogProducts);",
       "});"
      ]
     }
    }
   ],
   "request": {
