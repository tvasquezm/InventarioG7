        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"ORD-CRITICO-01\",\n  \"items\": [\n    {\n      \"productId\": \"660e8400-e29b-41d4-a716-446655440111\",\n      \"quantity\": 1\n    }\n  ]\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/inventory/reserve",
          "host": ["{{baseUrl}}"],
          "path": ["inventory", "reserve"]
        }
      }
    },
    {
      "name": "6. Concurrencia - Pedido B Compite Simultáneo (Rechazo 422)",
      "request": {
        "method": "POST",
        "header": [
