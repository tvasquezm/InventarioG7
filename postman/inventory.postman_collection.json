          { "key": "X-Correlation-Id", "value": "{{$guid}}", "type": "text" },
          { "key": "X-Consumer", "value": "payment-service", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"ORD-CRITICO-01\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/inventory/confirm",
          "host": ["{{baseUrl}}"],
          "path": ["inventory", "confirm"]
        }
      }
    }
  ],
  "variable": [
